            "url": {
              "raw": "{{base_sng_url}}/api/auth/health",
              "host": [
                "{{base_sng_url}}"
              ],
              "path": [
                "api",
                "auth",
                "health"
              ]
            }
          }
        },
        {
          "name": "Register (first user = admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) { pm.collectionVariables.set('token', res.token); }",
                  "if (res.user && res.user.id) { pm.collectionVariables.set('user_id', res.user.id); }",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shreenandi.com\",\n  \"password\": \"Admin@1234\",\n  \"name\": \"Super Admin\"\n}"
            },
            "url": {
